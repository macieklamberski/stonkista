{
  "name": "stonkista",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "docker compose -f .docker/docker-compose.dev.yml --env-file .docker/.env up --watch",
    "db:push": "drizzle-kit push --config src/database/config.ts",
    "db:generate": "drizzle-kit generate --config src/database/config.ts",
    "db:migrate": "drizzle-kit migrate --config src/database/config.ts",
    "db:seed": "bun src/database/seeds.ts",
    "test": "bun test"
  },
  "dependencies": {
    "bullmq": "^5.71.1",
    "drizzle-orm": "1.0.0-beta.19-d95b7a4",
    "hono": "^4.12.9",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "drizzle-kit": "1.0.0-beta.19-d95b7a4",
    "kvalita": "^1.11.1"
  }
}
