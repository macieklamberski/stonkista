{
  "name": "stonkista",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "docker compose -f .docker/docker-compose.dev.yml --env-file .docker/.env.dev up --watch",
    "db:push": "drizzle-kit push --config src/database/config.ts",
    "db:generate": "drizzle-kit generate --config src/database/config.ts",
    "db:migrate": "drizzle-kit migrate --config src/database/config.ts",
    "test": "bun test"
  },
  "dependencies": {
    "bullmq": "^5.73.2",
    "drizzle-orm": "0.45.2",
    "hono": "^4.12.12",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "drizzle-kit": "1.0.0-beta.20",
    "kvalita": "^1.12.4"
  }
}
